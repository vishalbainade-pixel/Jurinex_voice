APP_NAME=Jurinex_call_agent
APP_ENV=development
DEBUG=true
LOG_LEVEL=DEBUG
DEMO_MODE=true

PUBLIC_BASE_URL=https://your-public-domain.com

# Twilio
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+18159348556

# Gemini
GEMINI_API_KEY=your_gemini_api_key
GOOGLE_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-3.1-flash-live-preview
# Voice — one of: Aoede | Charon | Kore | Puck | Fenrir
GEMINI_VOICE=Aoede

# Database — local docker default (override via DATABASE_URL)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/jurinex_call_agent
# Voice agent DB (admin panel writes here). Leave blank to reuse DATABASE_URL.
JURINEX_VOICE_DATABASE_URL=

# Cloud SQL (production)
CLOUD_SQL_CONNECTION_NAME=your-gcp-project:region:instance
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=jurinex_call_agent

# ──────────────────────────────────────────────────────────────────────────
# Admin-side voice agent integration
# ──────────────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIM=768
KB_CHUNK_TOKENS=400
KB_CHUNK_OVERLAP=80
JURINEX_VOICE_LIVE_KB_BUDGET_BYTES=12000
JURINEX_VOICE_LIVE_KB_CHUNKS_PER_DOC=3
JURINEX_VOICE_TOOL_PROMPT_CACHE_MS=60000
JURINEX_VOICE_PROMPT_FRAGMENT_CACHE_MS=60000
JURINEX_VOICE_LIVE_WELCOME_TIMEOUT_MS=2000
JURINEX_VOICE_LIVE_TOOL_END_GRACE_MS=2000
JURINEX_VOICE_LIVE_MAX_RESUMES=3
# Calendar tool defaults (used by future calendar_check / calendar_book wiring)
JURINEX_VOICE_DEFAULT_CALENDAR_ID=
JURINEX_VOICE_DEFAULT_CALENDAR_TZ=Asia/Kolkata
JURINEX_VOICE_CALENDAR_SA_JSON_BASE64=
JURINEX_VOICE_CALENDAR_ALLOW_ATTENDEES=false

# Auth
SECRET_KEY=change_this_secret
ADMIN_API_KEY=change_me

# Knowledge base (RAG) — admin app populates kb_documents/kb_chunks; we read.
KB_ENABLED=true
KB_AGENT_NAME=preeti
KB_EMBEDDING_MODEL=gemini-embedding-001
KB_EMBEDDING_DIM=768
KB_SEARCH_K=5
KB_MIN_SCORE=0.60
KB_SHADOW_ENABLED=true
KB_SHADOW_MIN_SCORE=0.50

# Eager greeting — Twilio reads this immediately on pickup so the caller
# hears something within ~500ms instead of waiting 4-6s for Gemini Live
# cold-start. Set ENABLED=false to have Preeti deliver the greeting.
EAGER_GREETING_ENABLED=true
EAGER_GREETING_TEXT=नमस्ते, Jurinex support से संपर्क करने के लिए धन्यवाद। मैं Preeti बोल रही हूँ। मैं आपकी मदद English, Hindi या Marathi में कर सकती हूँ। आप कौन सी भाषा पसंद करेंगे?
EAGER_GREETING_VOICE=Google.hi-IN-Neural2-A
EAGER_GREETING_LANGUAGE=hi-IN
# Optional: pre-rendered greeting audio served from app/static/. If set,
# Twilio plays this WAV/MP3 instead of TTS-reading the text above.
# EAGER_GREETING_AUDIO_URL=/static/greeting.wav

# Human-agent transfer
SUPPORT_ADMIN_PHONE=+917885820020
TRANSFER_DIAL_TIMEOUT_SECONDS=30
# Language-specific on-hold message played while the admin phone rings.
# Preeti passes the caller's chosen language to the transfer tool and
# Twilio reads the matching variant in a localized voice.
TRANSFER_HOLD_MESSAGE_EN=Please stay on the line, I am connecting you to our Jurinex support team. While we connect you, here is a quick overview of Jurinex. Jurinex is an AI legal intelligence platform built for Indian lawyers. It includes a Smart Case Summarizer that condenses lengthy judgements in seconds, AI Case Creation that drafts plaints, writs and bail applications from basic facts, a real-time Citation Service powered by India Kanoon, and an AI Document Drafter for sale deeds, agreements, notices and more. A support specialist will be with you shortly. Thank you for your patience.
TRANSFER_HOLD_MESSAGE_HI=कृपया लाइन पर बने रहें, मैं आपको हमारी Jurinex support team से जोड़ रही हूँ। जब तक हम आपको जोड़ते हैं, आइए Jurinex के बारे में एक संक्षिप्त परिचय देते हैं। Jurinex भारतीय वकीलों के लिए बनाया गया एक AI Legal Intelligence Platform है। इसमें Smart Case Summarizer है जो लंबे judgements को सेकंडों में सारांश में बदल देता है, AI Case Creation है जो basic facts से plaints, writ petitions और bail applications तैयार करता है, India Kanoon से जुड़ी real-time Citation Service है, और AI Document Drafter है जो sale deeds, agreements, notices और बहुत कुछ बनाता है। एक support specialist बस कुछ ही पलों में आपसे बात करेंगे। आपके धैर्य के लिए धन्यवाद।
TRANSFER_HOLD_MESSAGE_MR=कृपया लाइनवर थांबा, मी तुम्हाला आमच्या Jurinex support team कडे जोडत आहे. जोपर्यंत आम्ही तुम्हाला जोडतो, तोपर्यंत Jurinex बद्दल थोडक्यात माहिती ऐका. Jurinex हे भारतीय वकीलांसाठी तयार केलेले AI Legal Intelligence Platform आहे. यात Smart Case Summarizer आहे जो लांब judgements काही सेकंदात summary मध्ये बदलतो, AI Case Creation आहे जे basic facts वरून plaints, writ petitions आणि bail applications तयार करते, India Kanoon शी जोडलेली real-time Citation Service आहे, आणि AI Document Drafter आहे जो sale deeds, agreements, notices आणि बरेच काही तयार करतो. एक support specialist काही क्षणांत तुमच्याशी बोलणार आहेत. तुमच्या संयमाबद्दल धन्यवाद.

# Voice for the on-hold TTS — Google Neural2 sounds closest to Preeti.
# Other options: Google.hi-IN-Wavenet-A, Polly.Aditi-Neural, Polly.Aditi, alice
TRANSFER_HOLD_VOICE_EN=Google.en-IN-Neural2-A
TRANSFER_HOLD_VOICE_HI=Google.hi-IN-Neural2-A
TRANSFER_HOLD_VOICE_MR=Google.mr-IN-Wavenet-A

# Call lifecycle (all in seconds where applicable)
SILENCE_TIMEOUT_SECONDS=30
MAX_CALL_DURATION_SECONDS=600
AUTO_HANGUP_ON_GEMINI_FAILURE=true
FAREWELL_GRACE_SECONDS=3
TECHNICAL_FAILURE_MESSAGE=We are experiencing a technical issue. Please call back in a few minutes. Goodbye.

# GCS call recordings (folder layout: gs://<bucket>/YYYY-MM-DD/HH-MM-SS_<callsid>/)
GCS_RECORDINGS_ENABLED=true
GCS_BUCKET=jurinex-voice
# Optional explicit project — usually only needed when the bucket is in a
# different project than the service account, or you want unambiguous logs.
GCS_PROJECT_ID=
# Auth — pick ONE:
#   (a) GCS_KEY_BASE64 — base64-encoded service-account JSON (preferred for Cloud Run / Docker)
#   (b) GOOGLE_APPLICATION_CREDENTIALS — path to a service-account JSON file
#   (c) leave both blank to use Application Default Credentials (Workload Identity)
GCS_KEY_BASE64=
GOOGLE_APPLICATION_CREDENTIALS=
