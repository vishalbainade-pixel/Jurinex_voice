APP_NAME=Jurinex_call_agent
APP_ENV=development
DEBUG=true
LOG_LEVEL=DEBUG
DEMO_MODE=true

PUBLIC_BASE_URL=https://your-public-domain.com

# Twilio
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+18159348556

# Gemini
GEMINI_API_KEY=your_gemini_api_key
GOOGLE_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-3.1-flash-live-preview
# Voice — one of: Aoede | Charon | Kore | Puck | Fenrir
GEMINI_VOICE=Aoede

# Database — local docker default (override via DATABASE_URL)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/jurinex_call_agent

# Cloud SQL (production)
CLOUD_SQL_CONNECTION_NAME=your-gcp-project:region:instance
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=jurinex_call_agent

# Auth
SECRET_KEY=change_this_secret
ADMIN_API_KEY=change_me
